  "keyFeatures": [
    "User authentication with role-based access control (Admin, User, Place Admin, Courier)",
    "Booking management with status tracking and lifecycle management",
    "Real-time shipment tracking and rider assignment",
    "Multi-tenant place and product management",
    "Integrated payment processing with Paystack",
    "Digital wallet system for managing transactions",
    "Rating and review system for service quality",
    "Analytics and reporting for business insights",
    "SMS notifications via Twilio integration",
    "PDF invoice generation for bookings"
  ],
  "publicApiSurface": [
    "POST /api/v1/auth/signup - User registration",
    "POST /api/v1/auth/login - User authentication",
    "GET /api/v1/auth/verify-account/:code - Account verification",
    "POST /api/v1/bookings - Create new booking",
    "GET /api/v1/bookings - List all bookings with filtering",
    "PUT /api/v1/bookings/:id/confirm-booking - Confirm booking",
    "POST /api/v1/shipping - Create shipment",
    "GET /api/v1/shipping/reference/:reference - Track shipment by reference",
    "PATCH /api/v1/shipping/:id/assign-rider/:riderId - Assign rider to shipment",
    "PATCH /api/v1/shipping/:id/update-history - Update shipment status with photo",
    "GET /api/v1/places - List all places",
    "POST /api/v1/products - Create product",
    "GET /api/v1/riders - List all riders",
    "POST /api/v1/payment/initialize - Initialize payment",
    "GET /api/v1/wallets - Get wallet information",
    "POST /api/v1/offers - Create promotional offer",
    "POST /api/v1/bookings/:id/rate - Rate a booking",
    "GET /api/v1/analytics - Get analytics data"
  ]
}
